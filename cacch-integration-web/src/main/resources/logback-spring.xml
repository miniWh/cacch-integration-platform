<?xml version="1.0" encoding="UTF-8"?>
<!--
  日志唯一配置入口（优先级高于 application*.yml 中的 logging.level 等）
  - 保留天数：7 天
  - TraceId：通过 TraceIdFilter 写入 MDC，格式 %X{traceId}
  - 非 prod：控制台 + 文件；prod：仅文件
-->
<configuration scan="true" scanPeriod="60 seconds">

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="APP_NAME" value="cacch-integration-platform"/>
    <property name="MAX_HISTORY" value="7"/>
    <property name="MAX_FILE_SIZE" value="100MB"/>
    <property name="TOTAL_SIZE_CAP" value="2GB"/>

    <!-- TraceId 来自 MDC（TraceIdFilter 注入）；无 TraceId 时显示 - -->
    <!-- %file:%line 输出源码文件名与行号（需采集调用栈，有轻微性能开销） -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [traceId:%X{traceId:-}] %-5level %logger{50} [%file:%line] - %msg%n"/>

    <!-- 按环境区分日志目录 -->
    <springProfile name="prod">
        <property name="LOG_PATH" value="/var/log/cacch-integration"/>
    </springProfile>
    <springProfile name="!prod">
        <property name="LOG_PATH" value="logs"/>
    </springProfile>

    <property name="LOG_FILE" value="${LOG_PATH}/${APP_NAME}"/>

    <!-- 控制台 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 文件：按天 + 按大小滚动 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}.log</file>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- ========== 测试 / 开发环境（spring.profiles.active=test） ========== -->
    <springProfile name="test">
        <logger name="com.cacch.integration" level="INFO"/>
        <!-- MyBatis SQL 走 SLF4J，禁止 application.yml 中使用 StdOutImpl -->
        <logger name="com.cacch.integration.mapper" level="DEBUG"/>
        <logger name="org.apache.ibatis" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- ========== 生产环境（spring.profiles.active=prod） ========== -->
    <springProfile name="prod">
        <logger name="com.cacch.integration" level="INFO"/>

        <root level="WARN">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- ========== 其他 profile 兜底 ========== -->
    <springProfile name="!test &amp; !prod">
        <logger name="com.cacch.integration" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>
